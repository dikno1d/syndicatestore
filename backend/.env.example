# =============================================================================
# SYNDICATE STORE - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT SECURITY NOTES:
# - NEVER commit the .env file to version control
# - Keep strong random values for all secrets
# - Rotate secrets regularly
# - Restrict file permissions: chmod 600 .env
# =============================================================================

# ---- Server ----
# Port the application will listen on
PORT=5000

# Set to "production" to enable secure cookie mode and disable debug output
# Leave empty or set to "development" for local development
NODE_ENV=development

# ---- MongoDB ----
# MongoDB connection string (Atlas or local)
# For Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# For local: mongodb://127.0.0.1:27017/gamingstore
MONGODB_URI=mongodb+srv://alexpluxury2_db_user:alex9012@cluster0.wbwdgff.mongodb.net/?appName=Cluster0

# ---- Default Admin Account ----
# Password for the default "admin" account created on first startup
# IMPORTANT: Change this immediately after first login
# Must be at least 8 characters
ADMIN_PASSWORD=change_this_to_a_strong_password

# ---- JWT (Session) Secret ----
# Used to sign admin session tokens
# Generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 characters
JWT_SECRET=generate_a_random_64_character_hex_string_here_minimum

# ---- eSewa Payment Gateway (Sandbox) ----
# Sandbox merchant ID and secret key for testing
ESEWA_MERCHANT_ID=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
# URLs eSewa redirects to after payment (must match your domain)
ESEWA_SUCCESS_URL=http://localhost:5000/api/payment/esewa/success
ESEWA_FAILURE_URL=http://localhost:5000/api/payment/esewa/failure

# ---- Google OAuth ---- 
# Google OAuth Client ID for customer login
GOOGLE_CLIENT_ID=your_google_client_id_here

# ---- Frontend URL ----
# Used for CORS redirects and the storefront link in admin panel
# In production: https://your-app.onrender.com
FRONTEND_URL=http://localhost:5000

# ---- CORS Allowed Origins ----
# Comma-separated list of allowed origins for API access
# Include all URLs that will access this server
# Example: http://localhost:5000,http://127.0.0.1:5500
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5500,http://localhost:5500
